{
  "name": "milesvault",
  "version": "0.0.0",
  "description": "MilesVault — AI-first credit card and rewards tracker",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "deploy": "opennextjs-cloudflare build --env=$CLOUDFLARE_ENV && node scripts/inject-do.mjs && opennextjs-cloudflare deploy --env=$CLOUDFLARE_ENV",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "devsafe": "rm -rf .next && rm -rf .open-next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:types": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "ii": "pnpm install --ignore-workspace",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "preview": "opennextjs-cloudflare build && node scripts/inject-do.mjs && opennextjs-cloudflare preview --env=$CLOUDFLARE_ENV",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts"
  },
  "dependencies": {
    "@ai-sdk-tool/parser": "^4.1.20",
    "@ai-sdk/openai-compatible": "^2.0.41",
    "@ai-sdk/react": "^3.0.163",
    "@cloudflare/ai-chat": "^0.4.6",
    "@cloudflare/think": "^0.3.0",
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/merge": "^6.12.1",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@lezer/highlight": "^1.2.3",
    "@opennextjs/cloudflare": "^1.11.0",
    "@uiw/react-codemirror": "^4.25.9",
    "agents": "^0.11.4",
    "ai": "^6.0.161",
    "beancount": "^0.2.5",
    "cross-env": "^7.0.3",
    "dotenv": "16.4.7",
    "lezer-beancount": "^1.1.0",
    "lucide-react": "^1.8.0",
    "lucide-static": "^1.8.0",
    "next": "15.4.11",
    "next-auth": "5.0.0-beta.31",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@ai-sdk/provider": "^3.0.8",
    "@eslint/eslintrc": "^3.2.0",
    "@playwright/test": "1.58.2",
    "@storybook/nextjs-vite": "^10.3.5",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "@testing-library/react": "16.3.0",
    "@types/node": "22.19.9",
    "@types/react": "19.2.9",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.5.2",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.16.0",
    "eslint-config-next": "15.4.11",
    "jsdom": "28.0.0",
    "postcss": "^8.5.10",
    "prettier": "^3.4.2",
    "storybook": "^10.3.5",
    "tailwindcss": "^3.4.19",
    "tsx": "4.21.0",
    "typescript": "5.7.3",
    "vite-tsconfig-paths": "6.0.5",
    "vitest": "4.0.18",
    "wrangler": "~4.61.1"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  },
  "cloudflare": {
    "bindings": {
      "AUTH_SECRET": {
        "description": "Generate via `openssl rand -base64 32`"
      },
      "AUTH_GOOGLE_ID": {
        "description": "Google OAuth 2.0 client ID"
      },
      "AUTH_GOOGLE_SECRET": {
        "description": "Google OAuth 2.0 client secret"
      }
    }
  }
}
