{
  "name": "milesvault",
  "version": "0.0.0",
  "description": "MilesVault — credit card and rewards tracker",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build:prompt": "node scripts/build-agent-prompt.mjs",
    "build": "pnpm build:prompt && cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build --webpack",
    "deploy": "pnpm build:prompt && opennextjs-cloudflare build --env=$CLOUDFLARE_ENV && node scripts/inject-do.mjs && opennextjs-cloudflare deploy --env=$CLOUDFLARE_ENV",
    "sync-dev-vars": "node scripts/sync-dev-vars.mjs",
    "dev": "pnpm sync-dev-vars && cross-env NODE_OPTIONS=--no-deprecation next dev --webpack",
    "devsafe": "rm -rf .next && rm -rf .open-next && pnpm sync-dev-vars && cross-env NODE_OPTIONS=--no-deprecation next dev --webpack",
    "generate:types": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "ii": "pnpm install --ignore-workspace",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "eval": "promptfoo eval -c evals/promptfooconfig.yaml --no-cache -j 1",
    "eval:view": "promptfoo view -y",
    "preview": "pnpm build:prompt && opennextjs-cloudflare build && node scripts/inject-do.mjs && opennextjs-cloudflare preview --env=$CLOUDFLARE_ENV",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.187",
    "@base-ui/react": "^1.5.0",
    "@cloudflare/ai-chat": "^0.7.1",
    "@cloudflare/codemode": "^0.3.8",
    "@cloudflare/think": "^0.7.1",
    "@codemirror/language": "^6.12.3",
    "@codemirror/merge": "^6.12.1",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@dagrejs/dagre": "^3.0.0",
    "@lezer/highlight": "^1.2.3",
    "@observablehq/plot": "^0.6.17",
    "@opennextjs/cloudflare": "^1.19.7",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@rive-app/react-webgl2": "^4.28.6",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@types/d3-hierarchy": "^3.1.7",
    "@uiw/react-codemirror": "^4.25.9",
    "@xyflow/react": "^12.10.2",
    "agents": "^0.13.1",
    "ai": "^6.0.185",
    "ansi-to-react": "^6.2.6",
    "beancount": "^0.2.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cross-env": "^7.0.3",
    "d3-hierarchy": "^3.1.2",
    "d3-sankey": "^0.12.3",
    "dayjs": "^1.11.20",
    "elkjs": "^0.11.1",
    "embla-carousel-react": "^8.6.0",
    "html-to-image": "^1.11.13",
    "lezer-beancount": "^1.1.0",
    "lucide-react": "^1.8.0",
    "media-chrome": "^4.19.0",
    "motion": "^12.40.0",
    "nanoid": "^5.1.11",
    "next": "16.2.5",
    "next-auth": "5.0.0-beta.31",
    "pdfjs-dist": "^5.7.284",
    "postal-mime": "^2.7.4",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-jsx-parser": "^2.4.1",
    "react-vega": "^8.0.0",
    "shadcn": "^4.8.0",
    "shiki": "^4.1.0",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "tokenlens": "^1.3.1",
    "topojson-client": "^3.1.0",
    "tw-animate-css": "^1.4.0",
    "use-stick-to-bottom": "^1.1.4",
    "vega": "^6.2.0",
    "vega-lite": "^6.4.3",
    "workers-ai-provider": "^3.1.14",
    "world-atlas": "^2.0.2",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@playwright/test": "1.58.2",
    "@storybook/nextjs-vite": "^10.3.5",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "@types/d3-sankey": "^0.12.5",
    "@types/node": "22.19.9",
    "@types/react": "19.2.9",
    "@types/react-dom": "19.2.3",
    "@types/topojson-client": "^3.1.5",
    "@types/topojson-specification": "^1.0.5",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.16.0",
    "eslint-config-next": "16.2.5",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "postcss": "^8.5.10",
    "prettier": "^3.4.2",
    "promptfoo": "^0.121.15",
    "storybook": "^10.3.5",
    "tailwindcss": "^3.4.19",
    "tsx": "4.21.0",
    "typescript": "5.7.3",
    "wrangler": "~4.88.0"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ],
    "patchedDependencies": {
      "@cloudflare/think@0.7.1": "patches/@cloudflare__think@0.7.1.patch"
    }
  },
  "cloudflare": {
    "bindings": {
      "AUTH_SECRET": {
        "description": "Generate via `openssl rand -base64 32`"
      },
      "AUTH_GOOGLE_ID": {
        "description": "Google OAuth 2.0 client ID"
      },
      "AUTH_GOOGLE_SECRET": {
        "description": "Google OAuth 2.0 client secret"
      }
    }
  }
}
