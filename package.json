{
  "name": "milesvault",
  "version": "0.0.0",
  "description": "MilesVault — credit card and rewards tracker",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "deploy": "opennextjs-cloudflare build --env=$CLOUDFLARE_ENV && node scripts/inject-do.mjs && opennextjs-cloudflare deploy --env=$CLOUDFLARE_ENV",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "devsafe": "rm -rf .next && rm -rf .open-next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:types": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "ii": "pnpm install --ignore-workspace",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "preview": "opennextjs-cloudflare build && node scripts/inject-do.mjs && opennextjs-cloudflare preview --env=$CLOUDFLARE_ENV",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@lezer/highlight": "^1.2.3",
    "@mantine/charts": "^9.1.1",
    "@mantine/core": "^9.1.1",
    "@mantine/dates": "^9.1.1",
    "@mantine/hooks": "^9.1.1",
    "@observablehq/plot": "^0.6.17",
    "@opennextjs/cloudflare": "^1.11.0",
    "@phosphor-icons/react": "^2.1.10",
    "@uiw/react-codemirror": "^4.25.9",
    "beancount": "^0.2.5",
    "cross-env": "^7.0.3",
    "d3-sankey": "^0.12.3",
    "dayjs": "^1.11.20",
    "lezer-beancount": "^1.1.0",
    "lucide-react": "^1.8.0",
    "next": "15.4.11",
    "next-auth": "5.0.0-beta.31",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@playwright/test": "1.58.2",
    "@storybook/nextjs-vite": "^10.3.5",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "@types/d3-sankey": "^0.12.5",
    "@types/node": "22.19.9",
    "@types/react": "19.2.9",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.16.0",
    "eslint-config-next": "15.4.11",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "postcss": "^8.5.10",
    "prettier": "^3.4.2",
    "storybook": "^10.3.5",
    "tailwindcss": "^3.4.19",
    "tsx": "4.21.0",
    "typescript": "5.7.3",
    "wrangler": "~4.61.1"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  },
  "cloudflare": {
    "bindings": {
      "AUTH_SECRET": {
        "description": "Generate via `openssl rand -base64 32`"
      },
      "AUTH_GOOGLE_ID": {
        "description": "Google OAuth 2.0 client ID"
      },
      "AUTH_GOOGLE_SECRET": {
        "description": "Google OAuth 2.0 client secret"
      }
    }
  }
}
