# Copy to .env on the OCI box and fill in. Never commit the real .env.

# Bot token from the Discord app (Dev Portal → Bot → Reset Token).
DISCORD_BOT_TOKEN=

# The concierge webhook the bridge forwards Gateway events to.
# Prod: https://milesvault.com/api/discord/webhook
MILESVAULT_WEBHOOK_URL=https://milesvault.com/api/discord/webhook

# Shared secret — must match the DISCORD_BRIDGE_SECRET set on the Worker
# (wrangler secret). Generate with: openssl rand -hex 32
DISCORD_BRIDGE_SECRET=
